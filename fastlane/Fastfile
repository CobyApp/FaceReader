default_platform(:ios)

WORKSPACE = "FaceReader.xcworkspace"
SCHEME = "FaceReader"
APP_IDENTIFIER = "com.coby.FaceReader"
TEAM_ID = "3Y8YH8GWMM"

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    sh("cd .. && bash Scripts/setup.sh")

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APPSTORE_KEY_ID"),
      issuer_id: ENV.fetch("APPSTORE_ISSUER_ID"),
      key_filepath: ENV.fetch("AUTH_KEY_PATH"),
      in_house: false
    )

    build_number = ENV["BUILD_NUMBER"] || begin
      latest = latest_testflight_build_number(
        app_identifier: APP_IDENTIFIER,
        api_key: api_key
      )
      (latest.to_i + 1).to_s
    end

    output_directory = ENV["RUNNER_TEMP"] || File.expand_path("../build", __dir__)

    build_app(
      workspace: WORKSPACE,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: output_directory,
      clean: true,
      xcargs: [
        "CURRENT_PROJECT_VERSION=#{build_number}",
        "CODE_SIGN_STYLE=Automatic",
        "DEVELOPMENT_TEAM=#{TEAM_ID}",
        "-allowProvisioningUpdates",
        "-authenticationKeyPath \"#{ENV.fetch("AUTH_KEY_PATH")}\"",
        "-authenticationKeyID \"#{ENV.fetch("APPSTORE_KEY_ID")}\"",
        "-authenticationKeyIssuerID \"#{ENV.fetch("APPSTORE_ISSUER_ID")}\""
      ].join(" ")
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )
  end
end
